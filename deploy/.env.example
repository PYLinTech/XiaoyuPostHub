# XiaoyuPostHub 配置

# 数据库
DATABASE_URL=

# 超级管理员
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD_HASH=

# Docker
XIAOYUPOSTHUB_IMAGE=pylintech/xiaoyuposthub:latest
XIAOYUPOSTHUB_PORT=8080
# 已有网络设为 true；由 Compose 创建的新网络设为 false
XIAOYUPOSTHUB_NETWORK=xiaoyuposthub-network
XIAOYUPOSTHUB_NETWORK_EXTERNAL=false

# 前端
STATIC_DIR=/app/web

# HTTPS 使用 true，直接 HTTP 使用 false
SESSION_COOKIE_SECURE=true

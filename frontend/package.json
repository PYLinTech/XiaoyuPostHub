{
  "name": "xiaoyuposthub-frontend",
  "version": "1.0.0",
  "description": "XiaoyuPostHub frontend",
  "proxy": "http://127.0.0.1:8080",
  "scripts": {
    "start": "react-app-rewired start",
    "dev": "react-app-rewired start",
    "build": "react-app-rewired build && npm run build:file-viewer-assets",
    "build:file-viewer-assets": "file-viewer-copy-assets ./build/libs/file-viewer",
    "eject": "react-scripts eject",
    "eslint": "eslint src/ --ext .ts,.tsx,.js,.jsx --fix --cache",
    "stylelint": "stylelint 'src/**/*.less' 'src/**/*.css' --fix --cache"
  },
  "dependencies": {
    "@arco-design/color": "0.4.0",
    "@arco-design/web-react": "2.66.16",
    "@file-viewer/react-legacy-full": "2.1.30",
    "assert": "2.1.0",
    "axios": "1.18.1",
    "browserify-zlib": "0.2.0",
    "buffer": "6.0.3",
    "classnames": "2.5.1",
    "dompurify": "3.4.12",
    "jszip": "3.10.1",
    "marked": "15.0.12",
    "path-browserify": "1.0.1",
    "process": "0.11.10",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-router-dom": "5.3.4",
    "stream-browserify": "3.0.0",
    "util": "0.12.5"
  },
  "devDependencies": {
    "@arco-plugins/webpack-react": "1.4.9",
    "@types/react": "17.0.93",
    "@types/react-dom": "17.0.26",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "customize-cra": "1.0.0",
    "customize-cra-less-loader": "2.0.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "8.10.2",
    "eslint-plugin-babel": "5.3.1",
    "eslint-plugin-prettier": "4.2.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "less": "4.6.7",
    "less-loader": "10.2.0",
    "postcss-less": "5.0.0",
    "prettier": "2.8.8",
    "react-app-rewired": "2.2.1",
    "react-scripts": "5.0.1",
    "stylelint": "14.16.1",
    "stylelint-config-prettier": "9.0.5",
    "stylelint-config-standard": "24.0.0",
    "typescript": "4.9.5"
  },
  "overrides": {
    "@babel/runtime": "7.29.7",
    "@types/d3-dispatch": "3.0.6",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
